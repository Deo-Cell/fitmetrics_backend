# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# format: postgres://user:password@host:port/database
# Pour Docker : postgres://fitmetrics:fitmetrics@db:5432/fitmetrics
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fitmetrics

# JWT Configuration
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=24h
